# Jayhind Invoice-OCR — configuration. Copy to `.env` and edit.
# Every setting has a production-safe default; you only need what you change.

# Server (loopback for the ERP sidecar). Leave OCR_API_KEY blank for no auth;
# set it to require `Bearer <key>` and match the hub's OCR_SERVICE_KEY.
OCR_HOST=127.0.0.1
OCR_PORT=8100
OCR_API_KEY=

# Reader: rapidocr (default — PP-OCR via ONNX, CPU-stable on ARM64) |
# paddleocr-vl | paddleocr (both need PaddlePaddle, which segfaults on this
# aarch64 CPU build) | null (digital-PDF text only, for tests).
OCR_READER_ENGINE=rapidocr

# Extractor: qwen (default, local Qwen3-8B via llama.cpp) or rules (no model).
OCR_EXTRACTOR_ENGINE=qwen
OCR_LLM_MODEL_PATH=models/Qwen3-8B-Q4_K_M.gguf
# Smaller GGUFs fit if 8B is too slow on CPU: Qwen3-4B / Qwen3-1.7B.

# CPU threads (this box has 4 vCPUs).
OCR_READER_CPU_THREADS=4
OCR_LLM_THREADS=4
